.DS_Store
/.webdriver_profiles
*.pyc
/data/
.env
/.venv
/node_modules
# User preferences (copy config.example.yaml → config.yaml; machine-specific).
/config.yaml
/config/config.yaml
# Activity logs (default location; override with CSB_LOG_DIR / --log-dir).
/logs/
csbmdvault/
csbmdvault/.obsidian/workspace.json
csbmdvault/.obsidian/graph.json
!csbmdvault/.obsidian
.build

# Compiled binaries (CLI + GUI). The .bin/.exe extensions let a single glob
# cover them; /csb is the legacy extensionless name.
*.bin
*.exe
/csb
# Rust / Tauri build artifacts (the GUI app binary + bundles).
/gui/src-tauri/target/
/gui/src-tauri/gen/
# Tauri sidecar: the Go binary cross-built by `just bundle` (target-triple named).
/gui/src-tauri/binaries/
