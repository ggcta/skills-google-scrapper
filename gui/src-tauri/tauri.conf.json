{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Google Skills Scraper",
  "version": "2.16.0",
  "identifier": "me.samdx.skills-scraper",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Google Skills Scraper",
        "width": 1040,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/skills-scraper"
    ],
    "resources": {
      "../../theme": "theme"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
